{
  "$schema": "https://opencode.ai/config.json",

  // Model
  "model": "anthropic/claude-sonnet-4-20250514",
  "small_model": "anthropic/claude-haiku-4-5",
  "default_agent": "build",
  "autoupdate": true,

  // Instructions — load AGENTS.md from root (default) + any extras
  "instructions": ["AGENTS.md"],

  // Permissions
  "permission": {
    "edit": "allow",
    "webfetch": "allow",
    "bash": {
      "rm -rf *": "deny",
      "git push *": "ask",
      "npm *": "allow",
      "pnpm *": "allow",
      "npx *": "allow",
      "*": "ask"
    }
  }
}
